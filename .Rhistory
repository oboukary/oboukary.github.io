library(rsdmx)
library(tidyverse)
# Codes ISO3 des pays CEDEAO
cedeo_countries <- c("BEN", "BFA", "CIV", "GMB", "GHA", "GIN", "GNB",
"LBR", "MLI", "NER", "NGA", "SEN", "SLE", "TGO")
# Indicateur U5MR
indicator <- "U5MR"
# Construire la query SDMX
base_url <- "https://sdmx.data.unicef.org/ws/public/sdmxapi/rest/data/UNICEF"
query <- paste0("/", indicator, ".", paste(cedeo_countries, collapse="+"))
full_url <- paste0(base_url, query, "?format=sdmx-json")
# Télécharger
sdmx_obj <- readSDMX(full_url)
